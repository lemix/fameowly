# OpenRouter API Key (for GPT-4o, Claude, Llama, etc.)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google Generative AI API Key (for Gemini models)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key-here

# JWT Secret for session management (generate a random 32+ char string)
JWT_SECRET=change-me-to-a-random-secret-string-at-least-32-chars

# Default admin password on first run
ADMIN_INIT_PASS=admin123
